      <script is:inline>
        let flipped = false;
        const flipCardElement = document.getElementById("flipCard"); // Get the card element
        const innerElement = document.getElementById("flipInner");
    
        function toggleFlip() {
          flipped = !flipped;
          if (flipped) {
            innerElement.style.transform = "rotateY(180deg)";
          } else {
            innerElement.style.transform = "rotateY(0deg)";
          }
        }
    
        // Optional: Add keyboard accessibility
        if (flipCardElement) {
            flipCardElement.setAttribute('tabindex', '0'); // Make it focusable
            flipCardElement.addEventListener('keydown', (event) => {
                // Trigger flip on Enter or Space key press
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault(); // Prevent default space scroll
                    toggleFlip();
                }
            });
        }
      </script>
    
      <style is:global>
        .perspective {
          perspective: 1200px;
